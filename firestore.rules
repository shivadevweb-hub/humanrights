rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == "shivadevweb@gmail.com";
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'createdAt', 'updatedAt']) 
        && data.uid is string && data.uid == request.auth.uid;
    }

    function isValidComplaint(data) {
      return data.keys().hasAll(['userId', 'content', 'createdAt', 'status'])
        && data.userId is string && data.userId == request.auth.uid;
    }

    function isValidTeamMember(data) {
      return data.keys().hasAll(['name', 'role', 'image', 'id'])
        && data.name is string && data.name.size() <= 100
        && data.role is string && data.role.size() <= 100
        && data.image is string && data.image.size() <= 1000;
    }

    function isValidGalleryImage(data) {
      return data.keys().hasAll(['url', 'caption', 'id'])
        && data.url is string && data.url.size() <= 1000
        && data.caption is string && data.caption.size() <= 200;
    }

    function isValidService(data) {
      return data.keys().hasAll(['title', 'description', 'id'])
        && data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 5000;
    }

    // --- Collection Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) 
        && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
        && incoming().uid == existing().uid
        && incoming().createdAt == existing().createdAt
        && incoming().updatedAt == request.time;
    }

    match /complaints/{complaintId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidId(complaintId) && isValidComplaint(incoming());
      allow update: if isSignedIn() && existing().userId == request.auth.uid 
        && isValidComplaint(incoming())
        && incoming().diff(existing()).affectedKeys().hasOnly(['content', 'status', 'analysis'])
        && incoming().userId == existing().userId
        && incoming().createdAt == existing().createdAt
        // Lock terminal state
        && existing().status != 'resolved';
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /team/{memberId} {
      allow read: if true;
      allow write: if isAdmin() && isValidTeamMember(incoming());
    }

    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin() && isValidGalleryImage(incoming());
    }

    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin() && isValidService(incoming());
    }
  }
}
